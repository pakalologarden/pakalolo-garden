---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Cannabis Concentrates Explained"
  description="Live resin, rosin, diamonds, sauce — explained without the hype."
>
  <div class="hero">
    <div class="hero-inner">
      <div class="breadcrumb">Concentrates</div>
      <h1>Cannabis Concentrates<br /><em>Explained</em></h1>
      <p class="hero-sub">Live resin, rosin, diamonds, sauce — explained without the hype.</p>
    </div>
  </div>
  <div class="hibiscus-divider">✿ &nbsp; ✿ &nbsp; ✿</div>
  <div style="max-width: var(--max-w); margin: 0 auto; padding: 4rem 2rem; text-align: center;">
    <p style="font-family: var(--font-mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.2em; color: var(--gold);">Coming Soon</p>
    <p style="margin-top: 1rem; color: var(--muted);">Pages building now. Check back soon.</p>
    <a href="/" style="display: inline-block; margin-top: 2rem; font-family: var(--font-mono); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--forest); border-bottom: 1px solid var(--gold); padding-bottom: 2px; text-decoration: none;">← Back To Home</a>
  </div>
</BaseLayout>
