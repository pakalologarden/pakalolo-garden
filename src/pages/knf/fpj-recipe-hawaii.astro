<ArticleLayout
  title="FPJ Recipe Hawaii — Fermented Plant Juice"
  description="My exact FPJ process for both veg and flower — what materials I use in Hawaii, the 1:1 sugar ratio, and how I apply it through the grow cycle."
  silo="KNF"
  siloSlug="knf"
  tags={['KNF', 'FPJ', 'Fermented Plant Juice', 'Hawaii', 'Living Soil']}
  date="June 2026"
