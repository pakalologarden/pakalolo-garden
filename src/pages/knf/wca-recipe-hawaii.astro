<ArticleLayout
  title="WCA Recipe Hawaii — Water Soluble Calcium"
  description="My exact WCA and CalPhos recipes — roasted eggshell and bone in brown rice vinegar. Real ratios and application rates for cannabis in Hawaii."
  silo="KNF"
  siloSlug="knf"
  tags={['KNF', 'WCA', 'CalPhos', 'Calcium', 'Hawaii']}
  date="June 2026"
