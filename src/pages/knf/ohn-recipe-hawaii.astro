  description="My exact OHN recipe using garlic, ginger, turmeric, and cinnamon. Real ratios, alcohol extraction process, and application rates from an Oahu garden."
  silo="KNF"
  siloSlug="knf"
  tags={['KNF', 'OHN', 'Oriental Herbal Nutrient', 'Hawaii', 'IPM']}
  date="June 2026"
