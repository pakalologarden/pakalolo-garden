<ArticleLayout
  title="329 Homegrow Hawaiʻi — What Medical Patients Can Actually Grow"
  description="A practical breakdown of Hawaii HRS §329 homegrow rights for medical cannabis patients. Plant counts, tagging rules, possession limits, caregiver rules, and what registration actually looks like."
  silo="Hawaiʻi Growing"
  siloSlug="hawaii-growing"
  tags={['329', 'Homegrow', 'Hawaii', 'Medical Cannabis', 'Legal']}
  date="June 2026"
